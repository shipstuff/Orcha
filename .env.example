# GitHub App Configuration
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Anthropic API Key (for Claude Code)
ANTHROPIC_API_KEY=

# Database
DATABASE_PATH=./data/orcha.db

# Workspace directory for cloned repos
WORKSPACE_DIR=./workspaces

# Server
PORT=3000
HOST=0.0.0.0

# Authorization
# Comma-separated list of GitHub usernames who can trigger agents directly
APPROVED_USERS=
# Comma-separated list of GitHub usernames who can /approve, /stop, /restart
MAINTAINERS=

# Agent Configuration
# Maximum concurrent agents
MAX_CONCURRENT_AGENTS=3
# Agent timeout in minutes
AGENT_TIMEOUT_MINUTES=60

# Label that triggers agent work
TRIGGER_LABEL=agent-work
