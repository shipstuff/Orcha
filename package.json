{
  "name": "orcha",
  "version": "1.0.0",
  "description": "GitHub issue-to-agent orchestrator using Claude Code instances",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/database/migrate.ts"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "@octokit/webhooks": "^13.2.0",
    "@octokit/auth-app": "^7.1.0",
    "better-sqlite3": "^11.3.0",
    "fastify": "^5.0.0",
    "zod": "^3.23.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "eslint": "^9.10.0",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
